PUID=1000
PGID=1000
TZ=America/Vancouver
# CONFIG: per-app config (outside the repo)
CONFIG=/opt/appdata
# DATA: shared media root — the 8 TB USB drive, mounted via fstab (UUID entry).
DATA=/data
# DATA_IMG: RETIRED hard storage cap (pre-USB-drive era). When set, $DATA becomes a
# fixed-size loopback ext4 image. MUST stay blank now: a from-scratch bootstrap with
# these populated would recreate the 20 GB cap, append a duplicate /data line to
# fstab, and mount the tiny image over the real drive's mountpoint.
DATA_IMG=
DATA_IMG_SIZE=

# ─── Provisioning (used by scripts/provision.sh; real values live in gitignored .env) ───
# LAN IP of this host — used for client URLs / API base.
NUC_IP=192.168.1.74
# Web controller dashboard port (served on the LAN at http://$NUC_IP:$CONTROLLER_PORT).
CONTROLLER_PORT=8088
# mDNS name published on the LAN so phones reach the dashboard by name with zero DNS
# config (http://$MDNS_NAME). Must end in .local (mDNS only handles that suffix).
# Installed via `make mdns`.
MDNS_NAME="movies.local movie.local"
# Service credentials. Deliberately uniform brennan/brennan — this is a private,
# isolated home LAN with no inbound exposure. Change if that ever stops being true.
QBIT_USER=brennan
QBIT_PASS=brennan
JELLYFIN_ADMIN_USER=brennan
JELLYFIN_ADMIN_PASS=brennan
# Bazarr subtitle provider (free OpenSubtitles.com account) — Phase 3, optional.
OPENSUBTITLES_USER=
OPENSUBTITLES_PASS=
# SuggestArr recommendations (free key: themoviedb.org/settings/api). Empty = SuggestArr
# stays idle; set it and run `make provision s=suggestarr` to activate.
TMDB_API_KEY=
# Radarr/Sonarr/Prowlarr/Bazarr API keys are DISCOVERED from each app's config.xml
# at provision time (pin-by-discovery), so they are intentionally not listed here.

# ─── VPN (ProtonVPN — routes ONLY qBittorrent through gluetun, ALWAYS ON) ────────
# Full setup in VPN.md. qBittorrent always exits via the VPN; if the tunnel drops,
# gluetun's kill-switch blocks it (fail-closed, no leak). To temporarily run direct
# for debugging: `make vpn-off` (and `make vpn-up` to restore).
#
# WireGuard private key from https://account.proton.me/u/0/vpn/WireGuard — generate a
# config with "Moderate NAT" ENABLED (that flag unlocks NAT-PMP port forwarding),
# then paste its PrivateKey value here. Secret: lives in .env only (gitignored).
VPN_WIREGUARD_PRIVATE_KEY=
# Exit-server country. PORT_FORWARD_ONLY already restricts to P2P/NAT-PMP servers;
# this keeps them close. Default Canada (nearest Vancouver); e.g. "Switzerland,Netherlands".
VPN_SERVER_COUNTRIES=Canada
# Local subnet(s) the VPN firewall must NOT block, so service-to-service traffic and
# the LAN keep reaching qBittorrent's WebUI. Default covers 192.168.x home LANs.
VPN_LAN_SUBNET=192.168.0.0/16
# These two make the VPN the default for EVERY compose/make command (that's the point —
# always on). COMPOSE_FILE layers the VPN overlay onto the base stack; QBIT_HOST tells
# the controller + *arr provisioners to reach qBittorrent at gluetun:8080 (it has no DNS
# name of its own once it shares gluetun's namespace). `make vpn-off` overrides both.
COMPOSE_FILE=docker-compose.yml:docker-compose.vpn.yml
QBIT_HOST=gluetun

# ─── Tailscale (join a self-hosted Headscale MESH) ───────────────────────────────
# Runs a host-networked, kernel-mode Tailscale node so this box's services become
# reachable over the private mesh at its 100.x.x.x IP (the LAN IP keeps working too).
# TS_LOGIN_SERVER: the Headscale coordination server URL (NOT tailscale.com SaaS).
TS_LOGIN_SERVER=https://headscale.example.com:8443
# TS_AUTHKEY: single-use pre-auth key. Consumed on first login only; node identity
# then persists in $CONFIG/tailscale. Blank = container fails to auth (harmless).
TS_AUTHKEY=
# TS_HOSTNAME: name this machine shows up as on the tailnet.
TS_HOSTNAME=movie-server

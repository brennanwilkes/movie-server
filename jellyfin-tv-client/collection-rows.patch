+/**
+ * Custom: scroll-away spotlight hero (first home row, via [HeroRowPresenter]). Picks, in order:
+ *  1. a Continue Watching item played in the last 24h, else the current Up Next episode
+ *  2. a movie added in the last 24h (highest community rating of those)
+ *  3. a random highly-rated movie (community rating >= 8.5, fallback 8.0)
+ * Shows backdrop + logo/title + Play (re-fetches full item via PlaybackHelper before playing).
+ */
+@Composable
+fun HomeSpotlight(modifier: Modifier = Modifier) {
+	val api = koinInject<ApiClient>()
+	val imageHelper = koinInject<ImageHelper>()
+	val playbackHelper = koinInject<PlaybackHelper>()
+	val context = LocalContext.current
+
+	var item by remember { mutableStateOf<BaseItemDto?>(null) }
+
+	LaunchedEffect(Unit) {
+		item = runCatching { withContext(Dispatchers.IO) { pickHeroItem(api) } }.getOrNull()
+	}
+
+	val hero = item ?: return
+	val backdropUrl = remember(hero) {
+		(hero.itemBackdropImages + hero.parentBackdropImages).firstOrNull()?.getUrl(api)
+	}
+	val logoUrl = remember(hero) { imageHelper.getLogoImageUrl(hero, 600) }
+	val title = hero.seriesName ?: hero.name.orEmpty()
+
+	Box(
+		modifier = modifier
+			.fillMaxWidth()
+			.height(SPOTLIGHT_HEIGHT)
+	) {
+		if (backdropUrl != null) {
+			AsyncImage(
+				model = backdropUrl,
+				contentDescription = null,
+				contentScale = ContentScale.Crop,
+				modifier = Modifier.fillMaxWidth().height(SPOTLIGHT_HEIGHT),
+			)
+		}
+		Box(
+			modifier = Modifier
+				.fillMaxWidth()
+				.height(SPOTLIGHT_HEIGHT)
+				.background(Brush.verticalGradient(listOf(Color(0x55000000), Color(0xE6000000)))),
+		)
+		Column(
+			modifier = Modifier
+				.align(Alignment.BottomStart)
+				.padding(start = 48.dp, end = 48.dp, bottom = 20.dp),
+		) {
+			if (logoUrl != null) {
+				AsyncImage(
+					model = logoUrl,
+					contentDescription = title,
+					contentScale = ContentScale.Fit,
+					modifier = Modifier.height(64.dp).widthIn(max = 420.dp),
+				)
+			} else {
+				Text(text = title, color = Color.White, fontSize = 34.sp, fontWeight = FontWeight.Bold)
+			}
+			Button(
+				onClick = { playbackHelper.retrieveAndPlay(hero.id, false, context) },
+				modifier = Modifier.padding(top = 14.dp),
+				content = { Text("▶  Play") },
+			)
+		}
+	}
+}
+
+private suspend fun pickHeroItem(api: ApiClient): BaseItemDto? {
+	val cutoff = LocalDateTime.now(ZoneOffset.UTC).minusHours(24)
+
+	// 1. Continue Watching played in the last 24h
+	runCatching {
+		api.itemsApi.getResumeItems(
+			GetResumeItemsRequest(mediaTypes = listOf(MediaType.VIDEO), limit = 1, fields = ItemRepository.itemFields)
+		).content.items.firstOrNull()
+	}.getOrNull()?.let { resume ->
+		val lastPlayed = resume.userData?.lastPlayedDate
+		if (lastPlayed != null && lastPlayed.isAfter(cutoff)) return resume
+	}
+
+	// 1b. Up Next episode (implies a series watched recently)
+	runCatching {
+		api.tvShowsApi.getNextUp(
+			GetNextUpRequest(limit = 1, fields = ItemRepository.itemFields)
+		).content.items.firstOrNull()
+	}.getOrNull()?.let { return it }
+
+	// 2. Movie added in the last 24h — highest community rating
+	runCatching {
+		api.itemsApi.getItems(
+			GetItemsRequest(
+				includeItemTypes = listOf(BaseItemKind.MOVIE),
+				recursive = true,
+				sortBy = listOf(ItemSortBy.DATE_CREATED),
+				sortOrder = listOf(SortOrder.DESCENDING),
+				limit = 20,
+				fields = ItemRepository.itemFields,
+			)
+		).content.items
+			.filter { (it.dateCreated?.isAfter(cutoff)) == true }
+			.maxByOrNull { it.communityRating ?: 0f }
+	}.getOrNull()?.let { return it }
+
+	// 3. Random highly-rated movie (>= 8.5, fallback 8.0)
+	return listOf(8.5, 8.0).firstNotNullOfOrNull { minRating ->
+		runCatching {
+			api.itemsApi.getItems(
+				GetItemsRequest(
+					includeItemTypes = listOf(BaseItemKind.MOVIE),
+					recursive = true,
+					minCommunityRating = minRating,
+					sortBy = listOf(ItemSortBy.RANDOM),
+					limit = 1,
+					fields = ItemRepository.itemFields,
+				)
+			).content.items.firstOrNull()
+		}.getOrNull()
+	}
+}
+
+private val SPOTLIGHT_HEIGHT = 320.dp
